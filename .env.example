# Public Vercel Blob URL for the Come Home background.
VITE_COME_HOME_BACKGROUND_URL=

# Prefer this server-only variable for Vercel Functions.
SUPABASE_URL=

# Server-only key used by /api/visit to store visit logs in Supabase.
SUPABASE_SERVICE_ROLE_KEY=

# Optional extra salt for anonymous visitor fingerprints.
VISIT_LOG_HASH_SALT=
